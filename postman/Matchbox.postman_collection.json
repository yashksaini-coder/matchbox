		{
			"name": "Matching Scenarios",
			"description": "End-to-end matching scenarios. Run these in order.\n\nNote: These assume a fresh order book. Flush Redis before running:\n`docker exec <redis-container> redis-cli FLUSHALL`",
			"item": [
				{
					"name": "Scenario 1: Full Match",
					"description": "Two orders at the same price and qty — both fully consumed.",
					"item": [
						{
							"name": "1a. Submit Sell 10@100",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"side\": \"sell\",\n    \"price\": 100,\n    \"qty\": 10\n}"
								},
								"url": {
									"raw": "{{base_url}}/orders",
									"host": ["{{base_url}}"],
									"path": ["orders"]
								}
							},
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"pm.test('Order created', function () {",
											"    pm.response.to.have.status(201);",
											"    pm.collectionVariables.set('scenario1_sell_id', pm.response.json().order_id);",
											"});"
										],
										"type": "text/javascript"
									}
								}
							]
						},
						{
							"name": "1b. Verify Sell Resting",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/orderbook",
									"host": ["{{base_url}}"],
									"path": ["orderbook"]
								}
							},
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"exec": [
											"// Wait for engine to process",
											"setTimeout(function(){}, 500);"
										],
										"type": "text/javascript"
									}
								},
								{
									"listen": "test",
									"script": {
										"exec": [
											"pm.test('Sell resting on asks', function () {",
											"    var book = pm.response.json();",
											"    pm.expect(book.asks.length).to.be.above(0);",
											"    pm.expect(book.asks[0].price).to.eql(100);",
											"    pm.expect(book.asks[0].qty).to.eql(10);",
											"    pm.expect(book.bids.length).to.eql(0);",
											"});"
										],
										"type": "text/javascript"
									}
								}
							]
						},
						{
							"name": "1c. Submit Buy 10@100 (crosses)",
							"request": {
								"method": "POST",
								"header": [
