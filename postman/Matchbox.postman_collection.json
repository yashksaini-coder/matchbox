		{
			"name": "Order Submission",
			"description": "Submit limit orders to the matching engine.",
			"item": [
				{
					"name": "Submit Buy Order",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"side\": \"buy\",\n    \"price\": 50,\n    \"qty\": 10\n}"
						},
						"url": {
							"raw": "{{base_url}}/orders",
							"host": ["{{base_url}}"],
							"path": ["orders"]
						},
						"description": "Submit a buy limit order.\n\n- `side`: \"buy\"\n- `price`: integer ticks (u64). e.g., 50 = $0.50 if tick = $0.01\n- `qty`: number of contracts (u64, must be > 0)\n\nReturns a globally unique order ID assigned via Redis INCR."
					},
					"response": [
						{
							"name": "Order Created",
							"originalRequest": {
								"method": "POST",
								"url": {
									"raw": "{{base_url}}/orders",
									"host": ["{{base_url}}"],
									"path": ["orders"]
								}
							},
							"status": "Created",
							"code": 201,
							"body": "{\"order_id\":1}"
						}
					],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has order_id', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('order_id');",
									"    pm.expect(jsonData.order_id).to.be.a('number');",
									"    pm.expect(jsonData.order_id).to.be.above(0);",
									"});",
									"",
									"// Save order_id for later use",
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('last_buy_order_id', jsonData.order_id);"
								],
								"type": "text/javascript"
							}
						}
					]
				},
